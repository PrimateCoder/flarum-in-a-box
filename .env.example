# Flarum-in-a-Box Configuration
# Copy this file to .env and customize as needed.
#
# NOTE: Setup is baked into the image at build time (admin account, DB,
# extensions, etc. are pre-configured). The only runtime override is the
# forum URL — useful if mapping to a non-default port.

# Forum URL (defaults to http://localhost:8080)
# If you map to a different port, set this to match.
# Example: -p 9090:80 → FLARUM_FORUM_URL=http://localhost:9090
FLARUM_FORUM_URL=http://localhost:8080

# Default credentials (set at build time, cannot be changed via env vars):
#   Admin: admin / password
#   User:  user  / password
