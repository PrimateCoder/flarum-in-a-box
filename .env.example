# Flarum-in-a-Box Configuration
# Copy this file to .env and customize as needed.

# Forum settings
FLARUM_FORUM_URL=http://localhost:8080
FLARUM_FORUM_TITLE=📦 Flarum-In-A-Box

# Admin account
FLARUM_ADMIN_USER=admin
FLARUM_ADMIN_PASS=password
FLARUM_ADMIN_EMAIL=admin@example.com

# Database (internal — only change if you know what you're doing)
FLARUM_DB_HOST=localhost
FLARUM_DB_NAME=flarum
FLARUM_DB_USER=flarum
FLARUM_DB_PASS=flarum
FLARUM_DB_PREFIX=flarum_
